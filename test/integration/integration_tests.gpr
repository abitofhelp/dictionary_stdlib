--  Integration test project for the Dictionary microservice.
--  Tests the Router dispatch through the full internal pipeline
--  (HTTP parsing → routing → validation → store → JSON).

with "../../dictionary_stdlib.gpr";

project Integration_Tests is

   for Source_Dirs use ("src/", "../common/");
   for Object_Dir use "obj";
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "../bin";
   for Main use ("integration_runner.adb");

   package Builder is
      for Executable ("integration_runner.adb")
        use "integration_runner";
   end Builder;

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g",
         "-gnatwa",
         "-gnatVa",
         "-gnaty3",
         "-gnatyb",
         "-gnatye",
         "-gnatyk",
         "-gnatym",
         "-gnatW8");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es");
   end Binder;

end Integration_Tests;
